# Jenkins
JENKINS_URL=http://192.168.50.x:8080
JENKINS_USER=admin
JENKINS_TOKEN=your_api_token

# Home Assistant
HA_URL=http://192.168.50.x:8123
HA_TOKEN=your_long_lived_access_token

# ASUS Router (opcional — también se puede pasar en router_login)
ASUS_ROUTER_URL=http://192.168.50.1
ASUS_ROUTER_USER=admin
ASUS_ROUTER_PASS=your_router_password

# Puerto del MCP server (default: 3000)
# PORT=3000
